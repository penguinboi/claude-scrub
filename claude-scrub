def discover_targets(claude_dir, ccrider_db=None):
    """Discover all Claude Code data files, categorized by type."""
    targets = {
        "sessions": [],
        "indexes": [],
        "history": [],
        "paste_cache": [],
        "file_history": [],
        "memory": [],
        "ccrider": [],
    }

    projects_dir = claude_dir / "projects"
    if projects_dir.is_dir():
        for project_dir in projects_dir.iterdir():
            if not project_dir.is_dir() or project_dir.is_symlink():
                continue
            for f in project_dir.iterdir():
                if f.is_symlink():
                    continue
                if f.suffix == ".jsonl" and f.is_file():
                    targets["sessions"].append(f)
                elif f.name == "sessions-index.json" and f.is_file():
                    targets["indexes"].append(f)
            mem_dir = project_dir / "memory"
            if mem_dir.is_dir() and not mem_dir.is_symlink():
                for f in mem_dir.iterdir():
                    if f.is_file() and not f.is_symlink():
                        targets["memory"].append(f)

    history = claude_dir / "history.jsonl"
    if history.is_file() and not history.is_symlink():
        targets["history"].append(history)

    paste_dir = claude_dir / "paste-cache"
    if paste_dir.is_dir() and not paste_dir.is_symlink():
        for f in paste_dir.iterdir():
            if f.is_file() and not f.is_symlink():
                targets["paste_cache"].append(f)

    fh_dir = claude_dir / "file-history"
    if fh_dir.is_dir() and not fh_dir.is_symlink():
        for f in fh_dir.iterdir():
            if f.is_file() and not f.is_symlink():
                targets["file_history"].append(f)

    if ccrider_db is None:
        ccrider_db = Path.home() / ".config" / "ccrider" / "sessions.db"
    if ccrider_db.is_file() and not ccrider_db.is_symlink():
        targets["ccrider"].append(ccrider_db)

    return targets


CATEGORY_ORDER = ("sessions", "indexes", "history", "paste_cache", "file_history", "memory", "ccrider")


def scan_targets(targets, patterns, show_progress=False):
    """Scan all target files for secrets, returning per-category results.

    Returns {category: {filepath: [(name, match_text, line_num, tier), ...], ...}, ...}.
    Files with no matches are omitted from the inner dict.
    When show_progress is True, prints each category result to stdout in real time.
    """
    global_total = sum(len(targets.get(c, [])) for c in CATEGORY_ORDER)
    global_done = 0
    global_secrets = 0
    start_time = time.monotonic()
    results = {}
    for category in CATEGORY_ORDER:
        files = targets.get(category, [])
        label = CATEGORY_LABELS.get(category, category)
        file_matches = {}
        cat_total = len(files)
        cat_secrets = 0
        for i, filepath in enumerate(files, 1):
            if show_progress:
                parts = [f"\r[{global_done + i}/{global_total}] {label + ':':<16}{i}/{cat_total}..."]
                running = global_secrets + cat_secrets
                if running > 0:
                    parts.append(f", {running} {'match' if running == 1 else 'matches'}...")
                elapsed = time.monotonic() - start_time
                files_done = global_done + i
                if elapsed >= 1.0 and files_done / global_total >= 0.05:
                    remaining = (elapsed / files_done) * (global_total - files_done)
                    parts.append(f"  (ETA ~{int(remaining + 0.5)}s)")
                # Pad to clear previous longer lines
                line = "".join(parts)
                print(f"{line:<80}", end="", flush=True)
            try:
                text = filepath.read_text(errors="replace")
            except OSError:
                continue
            matches = find_secrets(text, patterns)
            if matches:
                file_matches[filepath] = matches
                cat_secrets += len(matches)
        results[category] = file_matches
        global_done += cat_total
        global_secrets += cat_secrets
        if show_progress:
            file_noun = "file" if cat_total == 1 else "files"
            noun = "match" if cat_secrets == 1 else "matches"
            progress = f"\r[{global_done}/{global_total}] {label + ':':<16}"
            print(f"{progress}{cat_total} {file_noun} scanned, {cat_secrets} {noun} found")
    return results


def save_scan_cache(results, targets):
    """Save scan results to a JSON cache file for later use."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    cache = {"timestamp": datetime.now(timezone.utc).isoformat(), "categories": {}}
    for category in CATEGORY_ORDER:
        file_results = results.get(category, {})
        scanned_count = len(targets.get(category, []))
        serialized = {}
        for filepath, matches in file_results.items():
            serialized[str(filepath)] = [
                {"name": name, "line": line_num, "tier": tier} for name, match_text, line_num, tier in matches
            ]
        cache["categories"][category] = {
            "scanned": scanned_count,
            "files": serialized,
        }
    try:
        SCAN_CACHE_FILE.write_text(json.dumps(cache, indent=2))
    except OSError:
        pass


def load_scan_cache():
    """Load cached scan results if fresh enough. Returns (results, targets_summary) or (None, None)."""
    if not SCAN_CACHE_FILE.is_file():
        return None, None
    try:
        cache = json.loads(SCAN_CACHE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return None, None

    ts = cache.get("timestamp", "")
    try:
        cached_time = datetime.fromisoformat(ts)
        age = (datetime.now(timezone.utc) - cached_time).total_seconds()
        if age > SCAN_CACHE_MAX_AGE:
            return None, None
    except (ValueError, TypeError):
        return None, None

    results = {}
    targets_summary = {}
    for category, cat_data in cache.get("categories", {}).items():
        file_results = {}
        for filepath_str, matches_data in cat_data.get("files", {}).items():
            filepath = Path(filepath_str)
            matches = [
                (m["name"], m.get("match", "(redacted)"), m["line"], m.get("tier", "specific")) for m in matches_data
            ]
            file_results[filepath] = matches
        results[category] = file_results
        targets_summary[category] = cat_data.get("scanned", 0)
    return results, targets_summary


def filter_scrub_targets(targets, include=""):
    """Filter targets for scrub: sessions/indexes/history/memory always included.

    Optional categories (paste-cache, file-history, ccrider) are only
    included when named in the comma-separated include string. These are
    excluded by default because scrubbing could destroy useful clipboard
    content, file snapshots, or corrupt a third-party database.
    """
    included = set(s.strip() for s in include.split(",") if s.strip())
    VALID_INCLUDE = {"paste-cache", "file-history", "ccrider", "memory"}
    unknown = included - VALID_INCLUDE
    for name in sorted(unknown):
        print(
            f"Warning: unknown --include category '{name}' (valid: {', '.join(sorted(VALID_INCLUDE))})", file=sys.stderr
        )
    return {
        "sessions": targets.get("sessions", []),
        "indexes": targets.get("indexes", []),
        "history": targets.get("history", []),
        "memory": targets.get("memory", []),
        "paste_cache": targets["paste_cache"] if "paste-cache" in included else [],
        "file_history": targets["file_history"] if "file-history" in included else [],
        "ccrider": targets["ccrider"] if "ccrider" in included else [],
    }


def scrub_targets(targets, patterns, aggressive=False):
    """Replace secrets in-place across all target files.

    Returns stats dict with total_secrets, total_files, and per-category counts.
    By default, only redacts specific-tier patterns plus high-entropy generic
    matches. When aggressive=True, redacts all patterns unconditionally.
    """
    stats = {"total_secrets": 0, "total_files": 0, "categories": {}}
    for category, files in targets.items():
        cat_secrets = 0
        cat_files = 0
        for filepath in files:
            if filepath.is_symlink():
                continue
            try:
                original = filepath.read_text(errors="replace")
            except OSError:
                continue
            scrubbed = redact_secrets(original, patterns, aggressive=aggressive)
            if scrubbed != original:
                tmp_fd, tmp_path = tempfile.mkstemp(dir=filepath.parent, suffix=".tmp")
                try:
                    with os.fdopen(tmp_fd, "w") as tmp_f:
                        tmp_f.write(scrubbed)
                    os.replace(tmp_path, filepath)
                except BaseException:
                    os.unlink(tmp_path)
                    raise
                cat_files += 1
                cat_secrets += len(find_secrets(original, patterns))
        stats["categories"][category] = {"secrets": cat_secrets, "files": cat_files}
        stats["total_secrets"] += cat_secrets
        stats["total_files"] += cat_files
    return stats


def format_scan_report(results, verbose=False, targets=None):
    """Format scan results as a human-readable report.

    Default mode shows per-category summary. Verbose mode adds per-file
    detail with line numbers. When targets is provided, shows total files
    scanned per category (including clean files with no matches).
    """
    lines = ["Scanning Claude Code data...", ""]
    total_files_scanned = 0
    total_secrets = 0

    for category in CATEGORY_ORDER:
        if category not in results:
            continue
        file_results = results[category]
        label = CATEGORY_LABELS.get(category, category)

        scanned_count = len(targets[category]) if targets and category in targets else len(file_results)
        secret_count = sum(len(m) for m in file_results.values())
        total_files_scanned += scanned_count
        total_secrets += secret_count

        file_noun = "file" if scanned_count == 1 else "files"
        noun = "match" if secret_count == 1 else "matches"
        lines.append(f"{label + ':':<16}{scanned_count} {file_noun} scanned, {secret_count} {noun} found")

        if verbose and file_results:
            for filepath, matches in sorted(file_results.items(), key=lambda x: str(x[0])):
                short = shorten_project(str(filepath))
                lines.append(f"  {short}: {len(matches)} matches")
                for name, match_text, line_num, tier in matches:
                    preview = match_text[:20] + "..." if len(match_text) > 20 else match_text
                    lines.append(f"    Line {line_num}: {name} ({preview})")

    lines.append("")
    noun = "match" if total_secrets == 1 else "matches"
    file_noun = "file" if total_files_scanned == 1 else "files"
    lines.append(f"Total: {total_secrets} {noun} found across {total_files_scanned} {file_noun}")

    return "\n".join(lines)


