def parse_args(argv=None):
    """Parse command-line arguments using argparse with subcommands."""
    parser = argparse.ArgumentParser(
        prog="claude-scrub",
        description="Scan and scrub secrets from Claude Code session data.",
    )
    subparsers = parser.add_subparsers(dest="command")
    subparsers.required = True

    # --- scan subcommand ---
    scan_parser = subparsers.add_parser("scan", help="Scan sessions for secrets")
    scan_parser.add_argument("-v", "--verbose", action="store_true",
                             help="Show detailed output")
    scan_parser.add_argument("--patterns-db", action="store_true",
                             help="Use patterns-db for additional patterns")

    # --- scrub subcommand ---
    scrub_parser = subparsers.add_parser("scrub", help="Remove secrets from sessions")
    scrub_parser.add_argument("-v", "--verbose", action="store_true",
                              help="Show detailed output")
    scrub_parser.add_argument("-y", "--yes", action="store_true",
                              help="Skip confirmation prompts")
    scrub_parser.add_argument("--patterns-db", action="store_true",
                              help="Use patterns-db for additional patterns")
    scrub_parser.add_argument("--include", type=str, default=None,
                              help="Comma-separated data types to include")

    # --- sessions subcommand ---
    sessions_parser = subparsers.add_parser("sessions",
                                            help="List and resume sessions")
    sessions_parser.add_argument("--latest", action="store_true",
                                 help="Show only the most recent session per project")
    sessions_parser.add_argument("--days", type=int, default=DEFAULT_DAYS,
                                 help=f"Show sessions from the last N days (default: {DEFAULT_DAYS})")
    sessions_parser.add_argument("--all", action="store_true",
                                 help="Show all sessions regardless of age")
    sessions_parser.add_argument("--min-msgs", type=int, default=MIN_MESSAGES,
                                 dest="min_msgs",
                                 help=f"Minimum message count to include (default: {MIN_MESSAGES})")
    sessions_parser.add_argument("--print", action="store_true", dest="print_mode",
                                 help="Output markdown instead of interactive picker")
    sessions_parser.add_argument("-o", type=str, default=None,
                                 help="Write markdown to FILE (implies --print)")

    return parser.parse_args(argv)


# ---------------------------------------------------------------------------
# Print mode (markdown output, original behavior)
# ---------------------------------------------------------------------------

def print_mode_output(by_project, days, show_all, latest_only, output_file):
    """Generate markdown output to stdout or file."""
    if latest_only:
        for proj in by_project:
            by_project[proj] = by_project[proj][:1]

    lines = []
    lines.append("# Active Claude Sessions")
    lines.append("")
    if not show_all:
        lines.append(f"Last {days} days | Generated {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    else:
        lines.append(f"All sessions | Generated {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    lines.append("")

    for proj in sorted(by_project.keys()):
        proj_sessions = by_project[proj]
        lines.append(f"## {shorten_project(proj)}")
        lines.append("")

        for s in proj_sessions:
            date = format_date(s.get("modified") or s.get("created"))
            summary = make_summary(s)
            sid = s["sessionId"]
            branch = s.get("gitBranch", "")
            msgs = s.get("messageCount", 0)

            branch_str = f" (`{branch}`)" if branch else ""
            proj_path = shorten_project(s.get("project", ""))
            lines.append(f"- **{date}** — {summary}{branch_str} [{msgs} msgs]")
            lines.append(f'  `cd "{proj_path}" && claude --resume {sid}`')
            lines.append("")

    output = "\n".join(lines)

    if output_file:
        Path(output_file).write_text(output)
        print(f"Written to {output_file}", file=sys.stderr)
    else:
        print(output)


# ---------------------------------------------------------------------------
# Interactive mode (curses-based picker)
# ---------------------------------------------------------------------------

def truncate(text, width):
    """Truncate text to fit in width, adding ellipsis if needed."""
    if len(text) <= width:
        return text
    return text[:width - 1] + "\u2026"


def draw_header(stdscr, title, width):
    """Draw the header bar."""
    stdscr.attron(curses.A_BOLD)
    stdscr.addnstr(0, 0, " " * width, width, curses.color_pair(1))
    stdscr.addnstr(0, 1, title, width - 2, curses.color_pair(1))
    stdscr.attroff(curses.A_BOLD)


def draw_footer(stdscr, text, row, width):
    """Draw the footer help bar."""
    stdscr.addnstr(row, 0, " " * width, width, curses.color_pair(2))
    stdscr.addnstr(row, 1, text, width - 2, curses.color_pair(2))


def pick_from_list(stdscr, title, items, format_fn, footer_text):
    """Generic arrow-key picker. Returns selected index or -1 for back/quit."""
    curses.curs_set(0)
    selected = 0
    scroll_offset = 0

    while True:
        stdscr.clear()
        height, width = stdscr.getmaxyx()
        usable_rows = height - 3  # header + footer + padding

        if not items:
            draw_header(stdscr, title, width)
            stdscr.addnstr(2, 2, "(no sessions found)", width - 4)
            draw_footer(stdscr, "q quit", height - 1, width)
            stdscr.refresh()
            key = stdscr.getch()
            if key in (ord("q"), ord("Q"), 27):
                return -1
            continue

        # Adjust scroll to keep selection visible
        if selected < scroll_offset:
            scroll_offset = selected
        if selected >= scroll_offset + usable_rows:
            scroll_offset = selected - usable_rows + 1

        draw_header(stdscr, title, width)

        for i in range(usable_rows):
            idx = scroll_offset + i
            if idx >= len(items):
                break

            row = i + 1  # +1 for header
            is_selected = idx == selected
            line = format_fn(items[idx], width - 4)

            if is_selected:
                attr = curses.color_pair(3) | curses.A_BOLD
                prefix = "\u25b8 "
            else:
                attr = curses.color_pair(0)
                prefix = "  "

            display = prefix + line
            try:
                stdscr.addnstr(row, 0, truncate(display, width - 1), width - 1, attr)
            except curses.error:
                pass

        # Scroll indicator
        if len(items) > usable_rows:
            pct = int((selected / max(len(items) - 1, 1)) * 100)
            indicator = f" [{selected + 1}/{len(items)}] {pct}%"
            try:
                stdscr.addnstr(height - 2, width - len(indicator) - 1, indicator, len(indicator), curses.A_DIM)
            except curses.error:
                pass

        draw_footer(stdscr, footer_text, height - 1, width)
        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP or key == ord("k"):
            selected = max(0, selected - 1)
        elif key == curses.KEY_DOWN or key == ord("j"):
            selected = min(len(items) - 1, selected + 1)
        elif key in (curses.KEY_ENTER, 10, 13):
            return selected
        elif key in (27, curses.KEY_LEFT, ord("h"), curses.KEY_BACKSPACE, 127):
            return -1
        elif key == ord("q") or key == ord("Q"):
            return -2  # quit entirely
        elif key == curses.KEY_HOME:
            selected = 0
        elif key == curses.KEY_END:
            selected = len(items) - 1
        elif key == curses.KEY_NPAGE:  # Page Down
            selected = min(len(items) - 1, selected + usable_rows)
        elif key == curses.KEY_PPAGE:  # Page Up
            selected = max(0, selected - usable_rows)


def interactive_mode(stdscr, by_project):
    """Two-level picker: projects -> sessions -> resume."""
    # Set up colors
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_CYAN)    # header
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)   # footer
    curses.init_pair(3, curses.COLOR_CYAN, -1)                    # selected item

    # Sort projects by most recent session date
    project_list = []
    for proj, sessions in by_project.items():
        most_recent = max(
            (parse_timestamp(s.get("modified") or s.get("created")) for s in sessions),
            default=datetime.min.replace(tzinfo=timezone.utc),
        )
        session_count = len(sessions)
        total_msgs = sum(s.get("messageCount", 0) for s in sessions)
        project_list.append({
            "path": proj,
            "sessions": sessions,
            "most_recent": most_recent,
            "session_count": session_count,
            "total_msgs": total_msgs,
        })

    project_list.sort(key=lambda x: x["most_recent"], reverse=True)

    def format_project(item, width):
        short = shorten_project(item["path"])
        date = item["most_recent"].strftime("%Y-%m-%d") if item["most_recent"] != datetime.min.replace(tzinfo=timezone.utc) else "unknown"
        meta = f"{date}  {item['session_count']} sessions  {item['total_msgs']} msgs"
        available = width - len(meta) - 3
        name = truncate(short, max(available, 20))
        padding = " " * max(1, width - len(name) - len(meta) - 2)
        return f"{name}{padding}{meta}"

    def format_session(session, width):
        date = format_date(session.get("modified") or session.get("created"))
        branch = session.get("gitBranch", "")
        msgs = session.get("messageCount", 0)
        meta = f"{date}  {msgs:>4} msgs"
        if branch:
            meta = f"{date}  {branch}  {msgs:>4} msgs"
        summary = make_summary(session, max_len=width - len(meta) - 6)
        available = width - len(meta) - 3
        summary = truncate(summary, max(available, 20))
        padding = " " * max(1, width - len(summary) - len(meta) - 2)
        return f"{summary}{padding}{meta}"

    # Main loop: project picker
    while True:
        result = pick_from_list(
            stdscr,
            "Claude Sessions - Pick a project",
            project_list,
            format_project,
            "\u2191\u2193 navigate  \u23ce select  q quit",
        )

        if result < 0:
            return None  # quit

        proj = project_list[result]
        sessions = proj["sessions"]

        # Session picker for selected project
        while True:
            proj_title = f"{shorten_project(proj['path'])} ({len(sessions)} sessions)"
            sess_result = pick_from_list(
                stdscr,
                proj_title,
                sessions,
                format_session,
                "\u2191\u2193 navigate  \u23ce resume  \u2190/esc back  q quit",
            )

            if sess_result == -2:
                return None  # quit
            if sess_result == -1:
                break  # back to project list

            # Selected a session — return it
            return sessions[sess_result]


def launch_session(session):
    """Change to the project directory and exec into claude --resume."""
    project_dir = session.get("project", "")
    session_id = session["sessionId"]

    if project_dir and os.path.isdir(project_dir):
        os.chdir(project_dir)

    print(f"Resuming session in {shorten_project(project_dir)}...")
    print(f"  claude --resume {session_id}")
    print()

    # Replace this process with claude
    try:
        os.execvp("claude", ["claude", "--resume", session_id])
    except FileNotFoundError:
        print("Error: 'claude' not found in PATH", file=sys.stderr)
        sys.exit(1)


