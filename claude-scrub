def print_scan_totals(results, targets_summary, elapsed=None):
    """Print the Total line with tier breakdown from scan results."""
    total_matches = 0
    specific_count = 0
    generic_count = 0
    for cat in results.values():
        for matches in cat.values():
            for match in matches:
                total_matches += 1
                tier = match[3] if len(match) > 3 else "specific"
                if tier == "generic":
                    generic_count += 1
                else:
                    specific_count += 1
    if isinstance(targets_summary, dict) and all(isinstance(v, int) for v in targets_summary.values()):
        total_files = sum(targets_summary.values())
    else:
        total_files = sum(len(targets_summary.get(c, [])) for c in CATEGORY_ORDER)
    match_noun = "match" if total_matches == 1 else "matches"
    file_noun = "file" if total_files == 1 else "files"
    line = f"\nTotal: {total_matches} {match_noun} across {total_files} {file_noun}"
    if elapsed is not None:
        line += f" ({elapsed:.1f}s)"
    print(line)
    if total_matches > 0:
        print(f"\n  Secrets: {specific_count:>5} (specific pattern matches — scrubbed by default)")
        if generic_count > 0:
            print(f"  Generic: {generic_count:>5} (catch-all patterns — use --aggressive to scrub)")
        print("\n🔑 Exposed credentials should be rotated immediately —")
        print("   scrubbing removes local copies but doesn't revoke compromised secrets.")


def print_verbose_detail(results):
    """Print per-file, per-line detail with tier tags on generic matches."""
    for category in CATEGORY_ORDER:
        file_results = results.get(category, {})
        if file_results:
            label = CATEGORY_LABELS.get(category, category)
            print(f"\n{label}:")
            for filepath, matches in sorted(file_results.items(), key=lambda x: str(x[0])):
                short = shorten_project(str(filepath))
                print(f"  {short}: {len(matches)} matches")
                for name, match_text, line_num, *rest in matches:
                    tier = rest[0] if rest else "specific"
                    preview = match_text[:20] + "..." if len(match_text) > 20 else match_text
                    tier_tag = " [generic]" if tier == "generic" else ""
                    print(f"    Line {line_num}: {name}{tier_tag} ({preview})")


def build_rotation_list(results):
    """Build a rotation checklist from scan results.

    Groups matches by pattern name with occurrence count and date range
    (derived from file modification times). Returns a list of dicts sorted
    by count descending.
    """
    entries = {}  # name -> {"count": int, "earliest": date, "latest": date}
    for cat_results in results.values():
        for filepath, matches in cat_results.items():
            if not matches:
                continue
            try:
                mtime = datetime.fromtimestamp(filepath.stat().st_mtime, tz=timezone.utc)
                file_date = mtime.strftime("%Y-%m-%d")
            except OSError:
                file_date = "unknown"
            for name, _match_text, _line_num, *_rest in matches:
                if name not in entries:
                    entries[name] = {"name": name, "count": 0, "earliest": file_date, "latest": file_date}
                entries[name]["count"] += 1
                if file_date != "unknown":
                    if entries[name]["earliest"] == "unknown" or file_date < entries[name]["earliest"]:
                        entries[name]["earliest"] = file_date
                    if entries[name]["latest"] == "unknown" or file_date > entries[name]["latest"]:
                        entries[name]["latest"] = file_date
    return sorted(entries.values(), key=lambda e: -e["count"])


def format_rotation_list(rotation):
    """Format a rotation checklist as human-readable text."""
    if not rotation:
        return "No credentials found — nothing to rotate."
    lines = ["Credentials to rotate:", ""]
    for entry in rotation:
        date_range = entry["earliest"]
        if entry["latest"] != entry["earliest"]:
            date_range += f" – {entry['latest']}"
        noun = "occurrence" if entry["count"] == 1 else "occurrences"
        lines.append(f"  • {entry['name']}: {entry['count']} {noun} ({date_range})")
    return "\n".join(lines)


def save_rotation_list(rotation, fmt="text", config_dir=None):
    """Save the rotation checklist to disk.

    Returns the Path of the written file. Supports 'text' and 'json' formats.
    """
    if config_dir is None:
        config_dir = CONFIG_DIR
    config_dir.mkdir(parents=True, exist_ok=True)
    if fmt == "json":
        path = config_dir / "rotation-checklist.json"
        data = {
            "generated_at": datetime.now(timezone.utc).isoformat(),
            "credentials": rotation,
        }
        path.write_text(json.dumps(data, indent=2) + "\n")
    else:
        path = config_dir / "rotation-checklist.txt"
        header = f"Generated: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}\n\n"
        path.write_text(header + format_rotation_list(rotation) + "\n")
    return path


def gather_stats(claude_dir):
    """Mine session JSONL files for usage statistics."""
    projects_dir = claude_dir / "projects"
    total_sessions = 0
    total_user = 0
    total_assistant = 0
    project_sessions = {}  # project_name -> session count
    project_messages = {}  # project_name -> total messages
    first_ts = None
    biggest_file = None
    biggest_size = 0
    biggest_msgs = 0

    if projects_dir.is_dir():
        for pdir in projects_dir.iterdir():
            if not pdir.is_dir():
                continue
            project_name = pdir.name
            for jsonl_file in pdir.glob("*.jsonl"):
                total_sessions += 1
                project_sessions[project_name] = project_sessions.get(project_name, 0) + 1
                file_user = 0
                file_assistant = 0
                try:
                    with open(jsonl_file) as f:
                        for line in f:
                            try:
                                d = json.loads(line)
                            except json.JSONDecodeError:
                                continue
                            msg_type = d.get("type")
                            if msg_type == "user":
                                file_user += 1
                            elif msg_type == "assistant":
                                file_assistant += 1
                            ts = d.get("timestamp")
                            if ts:
                                dt = parse_timestamp(ts)
                                if dt and (first_ts is None or dt < first_ts):
                                    first_ts = dt
                except OSError:
                    continue
                total_user += file_user
                total_assistant += file_assistant
                file_msgs = file_user + file_assistant
                project_messages[project_name] = project_messages.get(project_name, 0) + file_msgs
                try:
                    fsize = jsonl_file.stat().st_size
                except OSError:
                    fsize = 0
                if fsize > biggest_size:
                    biggest_size = fsize
                    biggest_file = f"{project_name}/{jsonl_file.name}"
                    biggest_msgs = file_msgs

    # Disk usage across all of claude_dir
    disk_total = 0
    if claude_dir.is_dir():
        for dirpath, _dirnames, filenames in os.walk(claude_dir):
            for fname in filenames:
                try:
                    disk_total += os.path.getsize(os.path.join(dirpath, fname))
                except OSError:
                    pass

    # Most active project
    most_active = None
    most_active_sessions = 0
    most_active_msgs = 0
    for proj, count in project_sessions.items():
        if count > most_active_sessions:
            most_active = proj
            most_active_sessions = count
            most_active_msgs = project_messages.get(proj, 0)

    return {
        "total_sessions": total_sessions,
        "total_projects": len(project_sessions),
        "total_user_messages": total_user,
        "total_assistant_messages": total_assistant,
        "first_session_date": first_ts.strftime("%Y-%m-%d") if first_ts else None,
        "disk_usage_bytes": disk_total,
        "most_active_project": project_path_from_dir_name(most_active) if most_active else None,
        "most_active_project_sessions": most_active_sessions,
        "most_active_project_messages": most_active_msgs,
        "biggest_file_name": biggest_file,
        "biggest_file_size": biggest_size,
        "biggest_file_messages": biggest_msgs,
    }


def format_bytes(n):
    """Format byte count as human-readable size."""
    if n < 1024:
        return f"{n} B"
    elif n < 1024 * 1024:
        return f"{n / 1024:.1f} KB"
    elif n < 1024 * 1024 * 1024:
        return f"{n / (1024 * 1024):.1f} MB"
    else:
        return f"{n / (1024 * 1024 * 1024):.1f} GB"


def format_stats(stats):
    """Render stats dict into display text."""
    lines = ["📊 Claude Code Stats", ""]
    total_msgs = stats["total_user_messages"] + stats["total_assistant_messages"]
    lines.append(f"  Sessions:      {stats['total_sessions']:,} across {stats['total_projects']} projects")
    user = stats["total_user_messages"]
    assistant = stats["total_assistant_messages"]
    lines.append(f"  Messages:      {total_msgs:,} (you: {user:,} / claude: {assistant:,})")
    if stats["first_session_date"]:
        dt = datetime.strptime(stats["first_session_date"], "%Y-%m-%d")
        days_ago = (datetime.now() - dt).days
        lines.append(f"  First session: {stats['first_session_date']} ({days_ago} days ago)")
    lines.append(f"  Data on disk:  {format_bytes(stats['disk_usage_bytes'])}")
    if stats["most_active_project"]:
        proj = shorten_project(stats["most_active_project"])
        sessions = stats["most_active_project_sessions"]
        msgs = stats["most_active_project_messages"]
        lines.append(f"  Most active:   {proj} ({sessions} sessions, {msgs:,} msgs)")
    if stats["biggest_file_name"]:
        bf_name = stats["biggest_file_name"]
        bf_msgs = stats["biggest_file_messages"]
        bf_size = format_bytes(stats["biggest_file_size"])
        lines.append(f"  Biggest file:  {bf_name} ({bf_msgs:,} msgs, {bf_size})")
    return "\n".join(lines)


def cmd_stats(args):
    """Show Claude Code usage statistics."""
    stats = gather_stats(CLAUDE_DIR)
    print(format_stats(stats))


def prompt_save_rotation(rotation):
    """Ask the user if they want to save the rotation checklist to disk."""
    if not sys.stdout.isatty():
        return
    try:
        answer = input("\nSave rotation checklist? (t)ext, (j)son, or (N)o: ")
    except (EOFError, KeyboardInterrupt):
        return
    fmt = answer.strip().lower()
    if fmt in ("t", "text"):
        path = save_rotation_list(rotation, fmt="text")
        print(f"Saved to {path}")
    elif fmt in ("j", "json"):
        path = save_rotation_list(rotation, fmt="json")
        print(f"Saved to {path}")


def offer_rotation_list(results, force=False):
    """Print a rotation checklist, optionally prompting first.

    When force=True (--rotation-list flag), prints without asking.
    Otherwise prompts on interactive terminals when secrets are found.
    """
    rotation = build_rotation_list(results)
    if not rotation:
        return
    if force:
        print(f"\n{format_rotation_list(rotation)}")
        prompt_save_rotation(rotation)
        return
    if sys.stdout.isatty():
        try:
            answer = input("\nShow rotation checklist? [y/N] ")
        except (EOFError, KeyboardInterrupt):
            return
        if answer.lower() == "y":
            print(f"\n{format_rotation_list(rotation)}")
            prompt_save_rotation(rotation)


def cmd_scan(args):
    """Scan sessions for secrets."""
    # If verbose and we have a fresh cache, use it instead of rescanning
    if args.verbose:
        cached_results, cached_summary = load_scan_cache()
        if cached_results is not None:
            print("Using cached scan results (run 'scan' without --verbose to rescan)\n")
            # Print category summary with global counter
            global_total = sum(cached_summary.get(c, 0) for c in CATEGORY_ORDER)
            global_done = 0
            for category in CATEGORY_ORDER:
                file_results = cached_results.get(category, {})
                label = CATEGORY_LABELS.get(category, category)
                scanned = cached_summary.get(category, 0)
                global_done += scanned
                secret_count = sum(len(m) for m in file_results.values())
                file_noun = "file" if scanned == 1 else "files"
                noun = "match" if secret_count == 1 else "matches"
                progress = f"[{global_done}/{global_total}] {label + ':':<16}"
                print(f"{progress}{scanned} {file_noun} scanned, {secret_count} {noun} found")
            print_scan_totals(cached_results, cached_summary)
            print_verbose_detail(cached_results)
            offer_rotation_list(cached_results, force=args.rotation_list)
            return

    patterns = load_all_patterns(use_patterns_db=args.patterns_db)
    targets = discover_targets(CLAUDE_DIR)
    print("Scanning Claude Code data...\n")
    t0 = time.monotonic()
    results = scan_targets(targets, patterns, show_progress=True)
    elapsed = time.monotonic() - t0
    save_scan_cache(results, targets)
    print_scan_totals(results, targets, elapsed=elapsed)
    if args.verbose:
        print_verbose_detail(results)
    offer_rotation_list(results, force=args.rotation_list)


def cmd_scrub(args):
    """Remove secrets from session data."""
    patterns = load_all_patterns(use_patterns_db=args.patterns_db)
    all_targets = discover_targets(CLAUDE_DIR)

    # Try cache first, fall back to fresh scan
    cached_results, _ = load_scan_cache()
    if cached_results is not None:
        print("Using cached scan results\n")
        scan_results = cached_results
    else:
        print("Scanning Claude Code data...\n")
        scan_results = scan_targets(all_targets, patterns, show_progress=True)

    include = args.include if args.include else ""
    scrub_filtered = filter_scrub_targets(all_targets, include=include)

    # Count only matches in categories that will actually be scrubbed,
    # filtered by tier (specific only unless aggressive)
    scrub_categories = {cat for cat, files in scrub_filtered.items() if files}
    total = 0
    generic_skipped = 0
    for cat in scrub_categories:
        if cat not in scan_results:
            continue
        for matches in scan_results[cat].values():
            for match in matches:
                tier = match[3] if len(match) > 3 else "specific"
                if tier == "generic" and not args.aggressive:
                    generic_skipped += 1
                else:
                    total += 1
    if total == 0:
        print("\nNo secrets found. Nothing to scrub.")
        return

    # Summarize what would be scrubbed (shared by dry-run and real scrub)
    secret_counts = {}
    for cat_name in scrub_categories:
        if cat_name not in scan_results:
            continue
        for matches in scan_results[cat_name].values():
            for name, _match_text, _line_num, *rest in matches:
                tier = rest[0] if rest else "specific"
                if tier == "generic" and not args.aggressive:
                    continue
                secret_counts[name] = secret_counts.get(name, 0) + 1

    if args.dry_run:
        print(f"\nDry run: {total} secrets would be scrubbed.")
        if secret_counts:
            print("\nSecrets by type:")
            for name, count in sorted(secret_counts.items(), key=lambda x: -x[1]):
                print(f"  {name}: {count}")
            print("\nRun without --dry-run to scrub.")
        return

    if args.aggressive:
        print("\n⚠️  Aggressive mode: also scrubbing generic pattern matches.")
        print("   This may redact non-secret values and degrade session context.")

    claude_running = is_claude_code_running()
    if claude_running:
        print("\n🚨 Claude Code is currently running!")
        print("   Scrubbing rewrites session files in-place and WILL corrupt")
        print("   any active session. Close Claude Code first.")
    else:
        print("\n⚠️  Scrubbing rewrites session files in-place.")
        print("   Do not scrub while Claude Code is running — it may corrupt active sessions.")

    if not args.yes:
        answer = input(f"\nScrub {total} secrets? This cannot be undone. [y/N] ")
        if answer.lower() != "y":
            print("Aborted.")
            return

    stats = scrub_targets(scrub_filtered, patterns, aggressive=args.aggressive)
    print(f"\nScrubbed {stats['total_secrets']} secrets across {stats['total_files']} files.")

    if secret_counts:
        print("\nSecrets scrubbed by type:")
        for name, count in sorted(secret_counts.items(), key=lambda x: -x[1]):
            print(f"  {name}: {count}")
        print("\n🔑 Rotate these credentials NOW — scrubbing only removes local copies.")

    if generic_skipped > 0 and not args.aggressive:
        print(f"\n({generic_skipped} generic matches preserved — use --aggressive to include)")

    # Suggest rebuilding ccrider DB if it exists and wasn't directly scrubbed
    if "ccrider" not in scrub_categories and "ccrider" in scan_results:
        ccrider_secrets = sum(len(m) for m in scan_results["ccrider"].values())
        if ccrider_secrets > 0:
            print(f"\n📦 ccrider DB has {ccrider_secrets} secrets from cached sessions.")
            print("   Rebuild it from the now-scrubbed session files:")
            print("     ccrider sync --force")

    offer_rotation_list(scan_results, force=args.rotation_list)

    # Invalidate cache after scrubbing
    secure_delete(SCAN_CACHE_FILE)


