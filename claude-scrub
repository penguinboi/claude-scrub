def positive_int(value):
    """Argparse type for positive integers."""
    ivalue = int(value)
    if ivalue <= 0:
        raise argparse.ArgumentTypeError(f"{value} is not a positive integer")
    return ivalue


def parse_args(argv=None):
    """Parse command-line arguments using argparse with subcommands."""
    parser = argparse.ArgumentParser(
        prog="claude-scrub",
        description="Scan and scrub secrets from Claude Code session data.",
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    subparsers = parser.add_subparsers(dest="command")
    subparsers.required = True

    # --- scan subcommand ---
    scan_parser = subparsers.add_parser("scan", help="Scan sessions for secrets")
    scan_parser.add_argument("-v", "--verbose", action="store_true", help="Show detailed output")
    scan_parser.add_argument("--patterns-db", action="store_true", help="Use patterns-db for additional patterns")
    scan_parser.add_argument("--rotation-list", action="store_true", help="Print a checklist of credentials to rotate")

    # --- scrub subcommand ---
    scrub_parser = subparsers.add_parser("scrub", help="Remove secrets from sessions")
    scrub_parser.add_argument("-v", "--verbose", action="store_true", help="Show detailed output")
    scrub_parser.add_argument("-y", "--yes", action="store_true", help="Skip confirmation prompts")
    scrub_parser.add_argument("--patterns-db", action="store_true", help="Use patterns-db for additional patterns")
    scrub_parser.add_argument("--include", type=str, default=None, help="Comma-separated data types to include")
    scrub_parser.add_argument(
        "--dry-run", action="store_true", help="Show what would be scrubbed without modifying files"
    )
    scrub_parser.add_argument(
        "--aggressive", action="store_true", help="Also scrub generic pattern matches (may degrade session context)"
    )
    scrub_parser.add_argument("--rotation-list", action="store_true", help="Print a checklist of credentials to rotate")

    # --- stats subcommand ---
    subparsers.add_parser("stats", help="Show Claude Code usage statistics")

    # --- sessions subcommand ---
    sessions_parser = subparsers.add_parser("sessions", help="List and resume sessions")
    sessions_parser.add_argument("--latest", action="store_true", help="Show only the most recent session per project")
    sessions_parser.add_argument(
        "--days",
        type=positive_int,
        default=DEFAULT_DAYS,
        help=f"Show sessions from the last N days (default: {DEFAULT_DAYS})",
    )
    sessions_parser.add_argument("--all", action="store_true", help="Show all sessions regardless of age")
    sessions_parser.add_argument(
        "--min-msgs",
        type=int,
        default=MIN_MESSAGES,
        dest="min_msgs",
        help=f"Minimum message count to include (default: {MIN_MESSAGES})",
    )
    sessions_parser.add_argument(
        "--print", action="store_true", dest="print_mode", help="Output markdown instead of interactive picker"
    )
    sessions_parser.add_argument("-o", type=str, default=None, help="Write markdown to FILE (implies --print)")

    return parser.parse_args(argv)


