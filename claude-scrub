def project_path_from_dir_name(dir_name):
    """Convert a project directory name back to a path."""
    return dir_name.replace("-", "/")


def load_indexed_sessions():
    """Load sessions from all sessions-index.json files."""
    sessions = {}

    for index_file in PROJECTS_DIR.rglob("sessions-index.json"):
        try:
            data = json.loads(index_file.read_text())
            for entry in data.get("entries", []):
                sid = entry.get("sessionId")
                if sid:
                    sessions[sid] = {
                        "sessionId": sid,
                        "project": entry.get("projectPath", ""),
                        "summary": entry.get("summary", ""),
                        "firstPrompt": entry.get("firstPrompt", ""),
                        "messageCount": entry.get("messageCount", 0),
                        "created": entry.get("created", ""),
                        "modified": entry.get("modified", ""),
                        "gitBranch": entry.get("gitBranch", ""),
                        "source": "index",
                    }
        except (json.JSONDecodeError, OSError):
            continue

    return sessions


def extract_session_from_jsonl(jsonl_path):
    """Extract metadata from a session .jsonl file."""
    session_id = jsonl_path.stem
    meta = {
        "sessionId": session_id,
        "project": "",
        "summary": "",
        "firstPrompt": "",
        "messageCount": 0,
        "created": "",
        "modified": "",
        "gitBranch": "",
        "source": "jsonl",
    }

    user_msg_count = 0
    first_user_msg = None
    first_timestamp = None
    last_timestamp = None

    try:
        with open(jsonl_path) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue

                # Grab session metadata from any entry that has it
                if not meta["project"] and d.get("cwd"):
                    meta["project"] = d["cwd"]
                if not meta["gitBranch"] and d.get("gitBranch"):
                    meta["gitBranch"] = d["gitBranch"]

                # Track timestamps
                ts = d.get("timestamp")
                if ts:
                    if first_timestamp is None:
                        first_timestamp = ts
                    last_timestamp = ts

                # Count user messages and grab first one
                if d.get("type") == "user":
                    user_msg_count += 1
                    if first_user_msg is None:
                        msg = d.get("message", {})
                        content = msg.get("content", "")
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("type") == "text":
                                    first_user_msg = c["text"][:200]
                                    break
                        elif isinstance(content, str):
                            first_user_msg = content[:200]

        meta["messageCount"] = user_msg_count
        meta["firstPrompt"] = first_user_msg or ""
        meta["created"] = first_timestamp or ""
        meta["modified"] = last_timestamp or ""

        # If no project from session data, infer from directory path
        if not meta["project"]:
            parent = jsonl_path.parent.name
            meta["project"] = project_path_from_dir_name(parent)

    except OSError:
        pass

    return meta


def load_all_sessions():
    """Load from indexes first, then fill gaps from .jsonl files."""
    sessions = load_indexed_sessions()
    indexed_ids = set(sessions.keys())

    # Scan all .jsonl files for sessions not in any index
    for project_dir in PROJECTS_DIR.iterdir():
        if not project_dir.is_dir():
            continue
        for jsonl_file in project_dir.glob("*.jsonl"):
            sid = jsonl_file.stem
            if sid not in indexed_ids:
                meta = extract_session_from_jsonl(jsonl_file)
                if meta["messageCount"] >= MIN_MESSAGES:
                    sessions[sid] = meta

    return sessions


def parse_timestamp(ts):
    """Parse ISO timestamp or epoch millis to datetime."""
    if not ts:
        return None
    if isinstance(ts, (int, float)):
        return datetime.fromtimestamp(ts / 1000, tz=timezone.utc)
    try:
        # Handle ISO format with Z suffix
        ts = ts.replace("Z", "+00:00")
        return datetime.fromisoformat(ts)
    except (ValueError, AttributeError):
        return None


def format_date(ts):
    """Format a timestamp to YYYY-MM-DD."""
    dt = parse_timestamp(ts)
    if dt:
        return dt.strftime("%Y-%m-%d")
    return "unknown"


def shorten_project(path):
    """Shorten project path for display."""
    home = str(Path.home())
    if path.startswith(home):
        return "~" + path[len(home):]
    return path


def expand_project(path):
    """Expand ~ back to full home path."""
    if path.startswith("~"):
        return str(Path.home()) + path[1:]
    return path


def scrub_secrets(text):
    """Replace anything that looks like a secret with [REDACTED]."""
    for pattern in SECRET_PATTERNS:
        text = pattern.sub("[REDACTED]", text)
    return text


def clean_prompt(text):
    """Strip XML tags, plan prefixes, and other noise from a prompt."""
    if not text:
        return ""
    # Strip XML-style tags
    text = re.sub(r"<[^>]+>", "", text)
    # Strip "Implement the following plan:" prefix
    text = re.sub(r"^Implement the following plan:\s*", "", text)
    # Strip markdown headers used as plan titles
    text = re.sub(r"^#+\s*", "", text)
    # Collapse whitespace
    text = re.sub(r"\s+", " ", text).strip()
    return text


def is_noise_prompt(text):
    """Return True if the prompt matches a known noise pattern."""
    return any(p.search(text) for p in NOISE_PATTERNS)


def make_summary(session, max_len=80):
    """Build a one-line summary from available data."""
    summary = session.get("summary", "")
    if summary and summary not in USELESS_SUMMARIES:
        summary = scrub_secrets(summary)
        if len(summary) > max_len:
            summary = summary[:max_len - 3] + "..."
        return summary

    prompt = session.get("firstPrompt", "")
    if prompt and not is_noise_prompt(prompt):
        prompt = clean_prompt(prompt)
        prompt = scrub_secrets(prompt)
        if prompt:
            if len(prompt) > max_len:
                prompt = prompt[:max_len - 3] + "..."
            return prompt

    return "(no summary)"


def filter_and_group(sessions, days, show_all, min_messages):
    """Filter sessions by age/size, sort, and group by project."""
    cutoff = None
    if not show_all:
        cutoff = datetime.now(timezone.utc).timestamp() - (days * 86400)

    filtered = []
    for s in sessions.values():
        if s["messageCount"] < min_messages:
            continue
        mod_dt = parse_timestamp(s.get("modified") or s.get("created"))
        if cutoff and mod_dt:
            if mod_dt.timestamp() < cutoff:
                continue
        filtered.append(s)

    # Sort by modified date, newest first
    filtered.sort(
        key=lambda x: parse_timestamp(x.get("modified") or x.get("created"))
        or datetime.min.replace(tzinfo=timezone.utc),
        reverse=True,
    )

    # Group by project
    by_project = {}
    for s in filtered:
        proj = s.get("project", "unknown")
        by_project.setdefault(proj, []).append(s)

    return by_project


