def find_secrets(text, patterns):
    """Find all secret matches in text, returning (name, match_text, line_num, tier) tuples.

    Deduplicates overlapping matches: when a specific pattern and a generic
    catch-all pattern both match overlapping text on the same line, the generic
    match is dropped to avoid double-counting.

    Generic matches whose value portion has high Shannon entropy are promoted
    to tier "specific" (likely a real secret rather than a config placeholder).
    """
    matches = []
    lines = text.split("\n")
    for line_num, line in enumerate(lines, start=1):
        # Collect all matches on this line as (name, start, end, match_text, tier)
        line_matches = []
        for p in patterns:
            for m in p["regex"].finditer(line):
                line_matches.append((p["name"], m.start(), m.end(), m.group(), p.get("tier", "specific")))

        # Apply post-match validation (e.g., Luhn for credit cards)
        validated = []
        for name, start, end, match_text, tier in line_matches:
            validator = next((p.get("validate") for p in patterns if p["name"] == name), None)
            if validator == "luhn" and not luhn_check(match_text):
                continue
            validated.append((name, start, end, match_text, tier))
        line_matches = validated

        # Remove generic matches that overlap with any specific match
        specific = [(n, s, e) for n, s, e, _, _ in line_matches if n not in GENERIC_PATTERNS]
        for name, start, end, match_text, tier in line_matches:
            if name in GENERIC_PATTERNS:
                # Drop if any specific match overlaps this span
                if any(s < end and e > start for _, s, e in specific):
                    continue
            # Entropy-gated promotion: high-entropy generic values become specific
            effective_tier = tier
            if tier == "generic":
                eq_pos = match_text.find("=")
                if eq_pos < 0:
                    eq_pos = match_text.find(":")
                if eq_pos >= 0:
                    value = match_text[eq_pos + 1 :].strip()
                    if entropy(value) >= ENTROPY_THRESHOLD:
                        effective_tier = "specific"
            matches.append((name, match_text, line_num, effective_tier))
    return matches


def redact_secrets(text, patterns, aggressive=False):
    """Replace each secret match with [REDACTED:<pattern_name>].

    By default, only redacts specific-tier patterns plus generic matches
    with high entropy. When aggressive=True, redacts all patterns.
    """
    for p in patterns:
        tier = p.get("tier", "specific")
        if tier == "generic" and not aggressive:
            # Only redact high-entropy generic matches
            def _replace_if_high_entropy(m, pattern=p):
                matched = m.group()
                eq_pos = matched.find("=")
                if eq_pos < 0:
                    eq_pos = matched.find(":")
                if eq_pos >= 0:
                    value = matched[eq_pos + 1 :].strip()
                    if entropy(value) >= ENTROPY_THRESHOLD:
                        return f"[REDACTED:{pattern['name']}]"
                return matched  # Keep original

            text = p["regex"].sub(_replace_if_high_entropy, text)
        else:
            text = p["regex"].sub(f"[REDACTED:{p['name']}]", text)
    return text


