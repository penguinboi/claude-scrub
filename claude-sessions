#!/usr/bin/env python3
# ABOUTME: Generates a markdown summary of all Claude Code sessions across projects.
# ABOUTME: Outputs session ID, project, date, summary, and resume command.

import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

CLAUDE_DIR = Path.home() / ".claude"
PROJECTS_DIR = CLAUDE_DIR / "projects"

# How many days back to show (default: 30, override with --days N)
DEFAULT_DAYS = 30
# Minimum messages to count as a real session
MIN_MESSAGES = 3

# Patterns in first prompts that indicate noise rather than real conversation starts
NOISE_PATTERNS = [
    re.compile(r"^<local-command-caveat>"),
    re.compile(r"^\[Request interrupted"),
    re.compile(r"^<command-message>"),
    re.compile(r"^No prompt$"),
    re.compile(r"^exit$"),
    re.compile(r"^/compact"),
]

# Summaries that aren't useful
USELESS_SUMMARIES = {
    "No summary",
    "User Exits Session",
    "User Exited CLI Session",
}

# Patterns that match common secrets/credentials in text.
# Sourced from gitleaks, trufflehog, and h33tlit/secret-regex-list.
SECRET_PATTERNS = [
    # --- AI providers ---
    re.compile(r"sk-ant-api\d{2}-[A-Za-z0-9_-]{20,}"),
    re.compile(r"sk-ant-admin\d{2}-[A-Za-z0-9_-]{20,}"),
    re.compile(r"sk-proj-[A-Za-z0-9_-]{20,}"),
    re.compile(r"sk-[A-Za-z0-9]{20,}"),

    # --- Cloud providers ---
    # AWS access key IDs (AKIA, ASIA, ABIA, ACCA prefixes)
    re.compile(r"(?:AKIA|ASIA|ABIA|ACCA)[0-9A-Z]{16}"),
    re.compile(r"(?:aws_secret_access_key|secret_access_key)\s*[:=]\s*\S+", re.IGNORECASE),
    # Amazon MWS auth token
    re.compile(r"amzn\.mws\.[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"),
    # Google API key
    re.compile(r"AIza[0-9A-Za-z\-_]{35}"),
    # Google OAuth access token
    re.compile(r"ya29\.[0-9A-Za-z\-_]+"),
    # Google OAuth client ID
    re.compile(r"[0-9]+-[0-9A-Za-z_]{32}\.apps\.googleusercontent\.com"),
    # Azure AD client secret
    re.compile(r"[a-zA-Z0-9_~.]{3}\dQ~[a-zA-Z0-9_~.-]{31,34}"),

    # --- Payment ---
    # Stripe live/test keys
    re.compile(r"[sr]k_(?:test|live|prod)_[a-zA-Z0-9]{10,99}"),
    # Square access token & OAuth secret
    re.compile(r"sq0atp-[0-9A-Za-z\-_]{22}"),
    re.compile(r"sq0csp-[0-9A-Za-z\-_]{43}"),
    # PayPal Braintree access token
    re.compile(r"access_token\$production\$[0-9a-z]{16}\$[0-9a-f]{32}"),

    # --- Communication / email ---
    # Slack tokens (bot, user, app, workspace)
    re.compile(r"xox[pboa]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9-]*"),
    # Slack webhook URL
    re.compile(r"https://hooks\.slack\.com/services/T[a-zA-Z0-9_]{8}/B[a-zA-Z0-9_]{8}/[a-zA-Z0-9_]{24}"),
    # Discord bot/API token
    re.compile(r"(?:discord|bot)[\w.-]{0,20}[\s:=]+['\"]?[A-Za-z0-9._-]{50,}", re.IGNORECASE),
    # Twilio API key
    re.compile(r"SK[0-9a-fA-F]{32}"),
    # SendGrid API token
    re.compile(r"SG\.[a-zA-Z0-9=_\-.]{66}"),
    # Mailchimp API key
    re.compile(r"[0-9a-f]{32}-us[0-9]{1,2}"),
    # Mailgun API key
    re.compile(r"key-[0-9a-zA-Z]{32}"),

    # --- Dev platforms ---
    # GitHub tokens (PAT, OAuth, app, refresh)
    re.compile(r"gh[pousr]_[A-Za-z0-9_]{20,}"),
    # GitLab tokens (PAT, pipeline, runner)
    re.compile(r"gl(?:pat|ptt|rt)-[A-Za-z0-9_-]{20,}"),
    # npm access token
    re.compile(r"npm_[a-z0-9]{36}"),
    # PyPI API token
    re.compile(r"pypi-[A-Za-z0-9_-]{50,}"),
    # Shopify access token
    re.compile(r"shpat_[a-fA-F0-9]{32}"),
    # Heroku API key (UUID format, context-dependent)
    re.compile(r"(?:heroku)[\w.-]{0,20}[\s:=]+['\"]?[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}", re.IGNORECASE),
    # Notion API token
    re.compile(r"ntn_[0-9]{11}[A-Za-z0-9]{32,}"),
    # Postman API token
    re.compile(r"PMAK-[a-f0-9]{24}-[a-f0-9]{34}"),
    # Datadog API/app key
    re.compile(r"(?:datadog|dd)[\w.-]{0,20}[\s:=]+['\"]?[a-z0-9]{32,40}", re.IGNORECASE),
    # Vercel token
    re.compile(r"(?:vercel)[\w.-]{0,20}[\s:=]+['\"]?[A-Za-z0-9]{24,}", re.IGNORECASE),

    # --- Social / media ---
    # Facebook access token
    re.compile(r"EAACEdEose0cBA[0-9A-Za-z]+"),
    # Twitch API token
    re.compile(r"(?:twitch)[\w.-]{0,20}[\s:=]+['\"]?[a-z0-9]{30,}", re.IGNORECASE),

    # --- Cryptographic material ---
    # Private keys (RSA, DSA, EC, PGP, generic)
    re.compile(r"-----BEGIN[A-Z ]* PRIVATE KEY[A-Z ]*-----"),
    re.compile(r"-----BEGIN PGP PRIVATE KEY BLOCK-----"),
    # JWT tokens
    re.compile(r"\bey[a-zA-Z0-9]{17,}\.ey[a-zA-Z0-9/\\_-]{17,}\."),

    # --- Generic / catch-all ---
    re.compile(r"Bearer\s+[A-Za-z0-9._-]{20,}", re.IGNORECASE),
    re.compile(r"Authorization:\s*\S+", re.IGNORECASE),
    re.compile(r"(?:key|token|secret|password|credential|passwd|api_key|apikey)\s*[:=]\s*\S{8,}", re.IGNORECASE),
    # Passwords in URLs
    re.compile(r"://[^@\s]+:[^@\s]+@"),
    # Cloudinary URL (contains API secret)
    re.compile(r"cloudinary://[^\s]+"),
